datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ====================================================================
// ENUMS DEFINITIONS
// ====================================================================

enum EnterpriseStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
}

enum DocumentType {
  BUSINESS_LICENSE
  TAX_CERTIFICATE
  IDENTIFICATION
  OTHER
}

enum PeriodType {
  HALF_YEAR
  YEAR
}

enum PeriodStatus {
  DRAFT
  OPEN
  CLOSED
}

enum CategoryType {
  INJURY_TYPE
  INJURY_FACTOR
  OCCUPATION
  ACCIDENT_CAUSE
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum SectionType {
  ACCIDENT
  ALLOWANCE
}

// ====================================================================
// MODELS DEFINITIONS
// ====================================================================

model Role {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(255)
  parentId  Int?     @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  parent          Permission?      @relation("PermissionToParent", fields: [parentId], references: [id], map: "fk_permission_parent")
  children        Permission[]     @relation("PermissionToParent")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], map: "fk_rp_role")
  permission Permission @relation(fields: [permissionId], references: [id], map: "fk_rp_permission")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String?   @map("full_name") @db.VarChar(255)
  email        String?   @unique @db.VarChar(255)
  birthDate    DateTime? @map("birth_date") @db.Date
  gender       String?   @db.VarChar(20)
  position     String?   @db.VarChar(255)
  avatarUrl    String?   @map("avatar_url") @db.VarChar(500)
  provinceId   Int?      @map("province_id")
  wardId       Int?      @map("ward_id")
  address      String?   @db.Text
  roleId       Int       @map("role_id")
  
  // phien ban token cho moi user: khi doi pass check de logout
  tokenVersion Int       @default(0) @map("token_version")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  role                Role             @relation(fields: [roleId], references: [id], map: "fk_user_role")
  passwordResets      PasswordReset[]
  emailChangeOtps     EmailChangeOtp[]
  enterpriseProfile   Enterprise?      @relation("EnterpriseUser")
  approvedEnterprises Enterprise[]     @relation("EnterpriseApprovedBy")
  createdReports      Report[]         @relation("ReportCreatedBy")

  @@map("users")
}

model PasswordReset {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  otp          String   @db.Char(6)
  expiresAt    DateTime @map("expires_at")
  attemptCount Int      @default(0) @map("attempt_count")
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_password_reset_user")

  @@map("password_resets")
}

model EmailChangeOtp {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  newEmail     String   @map("new_email") @db.VarChar(255)
  otp          String   @db.Char(6)
  expiresAt    DateTime @map("expires_at")
  attemptCount Int      @default(0) @map("attempt_count")
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_email_change_user")

  @@map("email_change_otps")
}

model BusinessType {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(255)
  status    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  enterprises Enterprise[]

  @@map("business_types")
}

model BusinessField {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(255)
  parentId  Int?     @map("parent_id")
  level     Int      @default(1)
  status    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  parent      BusinessField?  @relation("BusinessFieldToParent", fields: [parentId], references: [id], map: "fk_business_field_parent")
  children    BusinessField[] @relation("BusinessFieldToParent")
  enterprises Enterprise[]

  @@map("business_fields")
}

model Enterprise {
  id                 Int              @id @default(autoincrement())
  userId             Int              @unique @map("user_id")
  taxCode            String           @unique @map("tax_code") @db.VarChar(50)
  licenseNumber      String           @unique @map("license_number") @db.VarChar(100)
  licenseIssueDate   DateTime?        @map("license_issue_date") @db.Date
  name               String           @db.VarChar(255)
  englishName        String?          @map("english_name") @db.VarChar(255)
  businessTypeId     Int              @map("business_type_id")
  businessFieldId    Int              @map("business_field_id")
  provinceId         Int?             @map("province_id")
  wardId             Int?             @map("ward_id")
  registeredAddress  String?          @map("registered_address") @db.Text
  operatingAddress   String?          @map("operating_address") @db.Text
  email              String?          @unique @db.VarChar(255)
  officePhone        String?          @map("office_phone") @db.VarChar(20)
  representativeName String?          @map("representative_name") @db.VarChar(255)
  representativePhone String?         @map("representative_phone") @db.VarChar(20)
  status             EnterpriseStatus @default(PENDING)
  approvedAt         DateTime?        @map("approved_at")
  approvedBy         Int?             @map("approved_by")
  rejectReason       String?          @map("reject_reason") @db.Text
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at")

  user          User          @relation("EnterpriseUser", fields: [userId], references: [id], map: "fk_enterprise_user")
  businessType  BusinessType  @relation(fields: [businessTypeId], references: [id], map: "fk_enterprise_business_type")
  businessField BusinessField @relation(fields: [businessFieldId], references: [id], map: "fk_enterprise_business_field")
  approver      User?         @relation("EnterpriseApprovedBy", fields: [approvedBy], references: [id], map: "fk_enterprise_approved_by")
  documents     EnterpriseDocument[]
  reports       Report[]

  @@map("enterprises")
}

model EnterpriseDocument {
  id           Int          @id @default(autoincrement())
  enterpriseId Int          @map("enterprise_id")
  documentName String       @map("document_name") @db.VarChar(255)
  documentType DocumentType @default(OTHER) @map("document_type")
  fileName     String       @map("file_name") @db.VarChar(255)
  filePath     String       @map("file_path") @db.VarChar(500)
  mimeType     String?      @map("mime_type") @db.VarChar(100)
  fileSize     Int?         @map("file_size")
  uploadedAt   DateTime     @default(now()) @map("uploaded_at")

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade, map: "fk_enterprise_document")

  @@map("enterprise_documents")
}

model ReportPeriod {
  id         Int          @id @default(autoincrement())
  reportName String       @map("report_name") @db.VarChar(255)
  year       Int
  periodType PeriodType   @map("period_type")
  startDate  DateTime?    @map("start_date") @db.Date
  endDate    DateTime?    @map("end_date") @db.Date
  status     PeriodStatus @default(DRAFT)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at")

  reports Report[]

  @@unique([year, periodType], name: "uq_report_period")
  @@map("report_periods")
}

model Category {
  id        Int          @id @default(autoincrement())
  type      CategoryType
  code      String       @db.VarChar(50)
  name      String       @db.VarChar(255)
  parentId  Int?         @map("parent_id")
  level     Int          @default(1)
  status    Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @default(now()) @updatedAt @map("updated_at")

  parent         Category?            @relation("CategoryToParent", fields: [parentId], references: [id], map: "fk_category_parent")
  children       Category[]           @relation("CategoryToParent")
  accidentCauses ReportAccidentCase[] @relation("CaseAccidentCause")
  injuryFactors  ReportAccidentCase[] @relation("CaseInjuryFactor")
  occupations    ReportAccidentCase[] @relation("CaseOccupation")

  @@unique([type, code], name: "uq_category")
  @@map("categories")
}

model Report {
  id                   Int          @id @default(autoincrement())
  enterpriseId         Int          @map("enterprise_id")
  reportPeriodId       Int          @map("report_period_id")
  status               ReportStatus @default(DRAFT)
  companyEmployeeTotal Int          @default(0) @map("company_employee_total")
  femaleEmployeeTotal  Int          @default(0) @map("female_employee_total")
  salaryFund           Decimal      @default(0) @map("salary_fund") @db.Decimal(18, 2)
  attachedFileName     String?      @map("attached_file_name") @db.VarChar(255)
  attachedFilePath     String?      @map("attached_file_path") @db.VarChar(500)
  submittedAt          DateTime?    @map("submitted_at")
  createdBy            Int          @map("created_by")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @default(now()) @updatedAt @map("updated_at")

  enterprise   Enterprise   @relation(fields: [enterpriseId], references: [id], map: "fk_report_enterprise")
  reportPeriod ReportPeriod @relation(fields: [reportPeriodId], references: [id], map: "fk_report_period")
  creator      User         @relation("ReportCreatedBy", fields: [createdBy], references: [id], map: "fk_report_user")
  sections     ReportSection[]

  @@unique([enterpriseId, reportPeriodId], name: "uq_report")
  @@map("reports")
}

model ReportSection {
  id                                 Int         @id @default(autoincrement())
  reportId                           Int         @map("report_id")
  sectionType                        SectionType @map("section_type")
  accidentCount                      Int         @default(0) @map("accident_count")
  fatalAccidentCount                 Int         @default(0) @map("fatal_accident_count")
  multiVictimAccidentCount           Int         @default(0) @map("multi_victim_accident_count")
  victimCount                        Int         @default(0) @map("victim_count")
  unmanagedCauseVictimCount          Int         @default(0) @map("unmanaged_cause_victim_count")
  femaleVictimCount                  Int         @default(0) @map("female_victim_count")
  unmanagedCauseFemaleVictimCount    Int         @default(0) @map("unmanaged_cause_female_victim_count")
  deathCount                         Int         @default(0) @map("death_count")
  unmanagedCauseDeathCount           Int         @default(0) @map("unmanaged_cause_death_count")
  severelyInjuredCount               Int         @default(0) @map("severely_injured_count")
  unmanagedCauseSeverelyInjuredCount Int         @default(0) @map("unmanaged_cause_severely_injured_count")
  medicalCost                        Decimal     @default(0) @map("medical_cost") @db.Decimal(18, 2)
  salaryCompensation                 Decimal     @default(0) @map("salary_compensation") @db.Decimal(18, 2)
  compensationCost                   Decimal     @default(0) @map("compensation_cost") @db.Decimal(18, 2)
  assetDamage                        Decimal     @default(0) @map("asset_damage") @db.Decimal(18, 2)
  daysLost                           Int         @default(0) @map("days_lost")
  createdAt                          DateTime    @default(now()) @map("created_at")
  updatedAt                          DateTime    @default(now()) @updatedAt @map("updated_at")

  report        Report               @relation(fields: [reportId], references: [id], onDelete: Cascade, map: "fk_section_report")
  accidentCases ReportAccidentCase[]

  @@unique([reportId, sectionType], name: "uq_report_section")
  @@map("report_sections")
}

model ReportAccidentCase {
  id                                 Int      @id @default(autoincrement())
  reportSectionId                    Int      @map("report_section_id")
  accidentCauseId                    Int?     @map("accident_cause_id")
  injuryFactorId                     Int?     @map("injury_factor_id")
  occupationId                       Int?     @map("occupation_id")
  accidentCount                      Int      @default(0) @map("accident_count")
  fatalAccidentCount                 Int      @default(0) @map("fatal_accident_count")
  multiVictimAccidentCount           Int      @default(0) @map("multi_victim_accident_count")
  victimCount                        Int      @default(0) @map("victim_count")
  unmanagedCauseVictimCount          Int      @default(0) @map("unmanaged_cause_victim_count")
  femaleVictimCount                  Int      @default(0) @map("female_victim_count")
  unmanagedCauseFemaleVictimCount    Int      @default(0) @map("unmanaged_cause_female_victim_count")
  deathCount                         Int      @default(0) @map("death_count")
  unmanagedCauseDeathCount           Int      @default(0) @map("unmanaged_cause_death_count")
  severelyInjuredCount               Int      @default(0) @map("severely_injured_count")
  unmanagedCauseSeverelyInjuredCount Int      @default(0) @map("unmanaged_cause_severely_injured_count")
  medicalCost                        Decimal  @default(0) @map("medical_cost") @db.Decimal(18, 2)
  salaryCompensation                 Decimal  @default(0) @map("salary_compensation") @db.Decimal(18, 2)
  compensationCost                   Decimal  @default(0) @map("compensation_cost") @db.Decimal(18, 2)
  assetDamage                        Decimal  @default(0) @map("asset_damage") @db.Decimal(18, 2)
  daysLost                           Int      @default(0) @map("days_lost")
  createdAt                          DateTime @default(now()) @map("created_at")
  updatedAt                          DateTime @default(now()) @updatedAt @map("updated_at")

  section       ReportSection @relation(fields: [reportSectionId], references: [id], onDelete: Cascade, map: "fk_case_section")
  accidentCause Category?     @relation("CaseAccidentCause", fields: [accidentCauseId], references: [id], map: "fk_case_accident")
  injuryFactor  Category?     @relation("CaseInjuryFactor", fields: [injuryFactorId], references: [id], map: "fk_case_factor")
  occupation    Category?     @relation("CaseOccupation", fields: [occupationId], references: [id], map: "fk_case_occupation")

  @@map("report_accident_cases")
}